async function subirCloudinary(file,pb,pf){
  if(pb)pb.style.display="block";
  const fd=new FormData();
  fd.append("file",file);fd.append("upload_preset",CLD_PRESET);fd.append("folder","fotos5s_gt");
  return new Promise((res,rej)=>{
    const xhr=new XMLHttpRequest();
    xhr.open("POST",`https://api.cloudinary.com/v1_1/${CLD_CLOUD}/image/upload`);
    xhr.upload.onprogress=e=>{if(pf&&e.lengthComputable)pf.style.width=Math.round(e.loaded/e.total*100)+"%";};
    xhr.onload=()=>{if(pb)pb.style.display="none";const r=JSON.parse(xhr.responseText);xhr.status===200?res(r.secure_url):rej(new Error(r.error?.message||"Upload failed"));};
    xhr.onerror=()=>rej(new Error("Network error"));
    xhr.send(fd);
  });
}

