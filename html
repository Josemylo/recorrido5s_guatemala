<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>Recorrido 5S — Guatemala</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<style>
:root{
  --green:#00693E;--green-d:#004D2E;--green-l:#00874F;
  --red:#E63329;--amber:#D97706;--blue:#1565C0;
  --g50:#F5F8F6;--g100:#E8EFEA;--g200:#C9D8CC;
  --g400:#7A9480;--g700:#2D3E30;--g900:#141E16;
  --r:10px;--sh:0 2px 14px rgba(0,105,62,.12);--shl:0 6px 32px rgba(0,105,62,.2);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Barlow",sans-serif;background:var(--g50);color:var(--g900);min-height:100vh;overflow-x:hidden}
header{background:var(--green);position:sticky;top:0;z-index:100;box-shadow:0 3px 18px rgba(0,0,0,.25)}
.hdr{display:flex;align-items:center;gap:12px;padding:8px 16px;max-width:720px;margin:0 auto}
.hdr-brand{flex:1}
.logo-box{background:#fff;border-radius:8px;padding:4px 8px;flex-shrink:0}
.logo-box img{height:40px;display:block;object-fit:contain}
.hdr-brand h1{font-family:"Barlow Condensed",sans-serif;font-size:19px;font-weight:800;color:#fff;letter-spacing:.5px;line-height:1.1}
.hdr-brand span{font-size:11px;color:rgba(255,255,255,.75)}
.hdr-sync{background:rgba(255,255,255,.15);border:none;color:#fff;border-radius:7px;padding:7px 11px;font-size:12px;font-weight:600;cursor:pointer;font-family:"Barlow",sans-serif;transition:background .18s}
.hdr-sync:hover{background:rgba(255,255,255,.28)}
nav{background:var(--green-d);display:flex;overflow-x:auto;scrollbar-width:none}
nav::-webkit-scrollbar{display:none}
.tab{flex-shrink:0;padding:11px 20px;color:rgba(255,255,255,.55);font-family:"Barlow Condensed",sans-serif;font-size:15px;font-weight:700;cursor:pointer;border-bottom:3px solid transparent;transition:all .18s;user-select:none;white-space:nowrap}
.tab.active{color:#fff;border-bottom-color:var(--amber)}
.tab:hover:not(.active){color:rgba(255,255,255,.85)}
main{max-width:720px;margin:0 auto;padding:18px 14px 100px}
.section{display:none}.section.active{display:block}
.card{background:#fff;border-radius:var(--r);box-shadow:var(--sh);padding:18px;margin-bottom:14px}
.card-title{font-family:"Barlow Condensed",sans-serif;font-size:17px;font-weight:700;color:var(--green);margin-bottom:14px;text-transform:uppercase;letter-spacing:.4px;border-left:4px solid var(--amber);padding-left:10px}
.fg{margin-bottom:13px}
label{display:block;font-size:11px;font-weight:600;color:var(--g700);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
.req{color:var(--red);margin-left:2px}
select,input[type=text],textarea{width:100%;padding:10px 12px;border:1.5px solid var(--g200);border-radius:8px;font-family:"Barlow",sans-serif;font-size:15px;color:var(--g900);background:#fff;transition:border-color .18s;-webkit-appearance:none}
select:focus,input:focus,textarea:focus{outline:none;border-color:var(--green)}
select:disabled{background:var(--g50);color:var(--g400);cursor:not-allowed}
textarea{resize:vertical;min-height:88px}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.btn-primary{background:var(--green);color:#fff;width:100%;padding:12px;border:none;border-radius:8px;font-family:"Barlow",sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:background .18s;display:flex;align-items:center;justify-content:center;gap:8px}
.btn-primary:hover{background:var(--green-l)}
.btn-primary:disabled{background:var(--g200);cursor:not-allowed;color:var(--g400)}
.btn-ghost{background:transparent;color:var(--green);border:1.5px solid var(--green);padding:7px 12px;font-size:13px;border-radius:8px;cursor:pointer;font-family:"Barlow",sans-serif;font-weight:600;transition:all .18s;display:inline-flex;align-items:center;gap:4px}
.btn-ghost:hover{background:var(--green);color:#fff}
.s-sel{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.s-btn{padding:9px 6px;border:2px solid var(--g200);border-radius:8px;background:#fff;cursor:default;pointer-events:none;text-align:center;font-family:"Barlow Condensed",sans-serif;font-size:13px;font-weight:700;transition:all .15s;color:var(--g700)}
.s-btn span{display:block;font-size:10px;font-weight:400;margin-top:2px;opacity:.8}
.s-btn.active{border-color:var(--green);background:var(--green);color:#fff}
.photo-drop{border:2px dashed var(--g200);border-radius:8px;padding:18px;text-align:center;cursor:pointer;transition:all .18s;position:relative}
.photo-drop:hover{border-color:var(--green);background:var(--g50)}
.photo-drop input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.photo-prev{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.photo-prev img{width:68px;height:68px;object-fit:cover;border-radius:6px;border:2px solid var(--g200)}
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;font-family:"Barlow Condensed",sans-serif;letter-spacing:.4px;text-transform:uppercase}
.b-1s{background:#FFF3E0;color:#E65100}.b-2s{background:#E8F5E9;color:#1B5E20}
.b-3s{background:#E3F2FD;color:#0D47A1}.b-4s{background:#F3E5F5;color:#4A148C}
.b-5s{background:#FCE4EC;color:#880E4F}.b-epp{background:#FFF3E0;color:#E65100}
.b-ok{background:#E8F5E9;color:#1B5E20}.b-no{background:#FFEBEE;color:#B71C1C}
.obs-card{background:#fff;border-radius:var(--r);box-shadow:var(--sh);margin-bottom:10px;border-left:4px solid var(--g200);overflow:hidden;cursor:pointer;transition:box-shadow .18s}
.obs-card:hover{box-shadow:var(--shl)}
.obs-card.corregido{border-left-color:var(--green)}
.obs-card.no-corregido{border-left-color:var(--red)}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.58);z-index:200;padding:16px;overflow-y:auto}
.modal-overlay.show{display:flex;align-items:flex-start;justify-content:center}
.modal{background:#fff;border-radius:14px;padding:20px;width:100%;max-width:500px;box-shadow:var(--shl);margin:auto}
.modal-title{font-family:"Barlow Condensed",sans-serif;font-size:18px;font-weight:800;color:var(--green);margin-bottom:16px;text-transform:uppercase;border-left:4px solid var(--amber);padding-left:10px}
/* DASHBOARD */
.kpi-box{background:#fff;border-radius:8px;box-shadow:var(--sh);padding:10px 6px;text-align:center;border-top:3px solid var(--g200)}
.kpi-box.green{border-top-color:var(--green)}.kpi-box.red{border-top-color:var(--red)}.kpi-box.amber{border-top-color:var(--amber)}
.kpi-val{font-family:"Barlow Condensed",sans-serif;font-size:24px;font-weight:800;line-height:1;color:var(--g900)}
.kpi-box.green .kpi-val{color:var(--green)}.kpi-box.red .kpi-val{color:var(--red)}.kpi-box.amber .kpi-val{color:var(--amber)}
.kpi-lbl{font-size:9px;color:var(--g400);font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-top:2px}
.dash-card{background:#fff;border-radius:10px;box-shadow:var(--sh);padding:12px 12px 14px;margin-bottom:12px}
.dash-card-title{font-family:"Barlow Condensed",sans-serif;font-size:12px;font-weight:700;color:var(--g700);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;border-left:3px solid var(--amber);padding-left:8px}
.dash-legend-row{display:flex;align-items:center;gap:6px;padding:3px 0;border-bottom:1px solid var(--g100)}
.dash-legend-row:last-child{border-bottom:none}
.dash-legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dash-legend-label{font-size:10px;color:var(--g700);flex:1}
.dash-legend-val{font-family:"Barlow Condensed",sans-serif;font-size:13px;font-weight:700;color:var(--g900)}
.dash-legend-pct{font-size:10px;color:var(--g400);min-width:30px;text-align:right}
.period-sel{display:flex;border-radius:8px;overflow:hidden;border:1.5px solid var(--g200)}
.period-btn{flex:1;padding:7px;border:none;background:#fff;font-family:"Barlow",sans-serif;font-size:11px;font-weight:600;cursor:pointer;color:var(--g400);transition:all .18s}
.period-btn.active{background:var(--green);color:#fff}
.filter-small{padding:8px 10px;border:1.5px solid var(--g200);border-radius:8px;font-family:"Barlow",sans-serif;font-size:12px;-webkit-appearance:none;background:#fff;width:100%}
.dtbl{width:100%;border-collapse:collapse;font-size:11px}
.dtbl th{background:var(--green);color:#fff;padding:6px 8px;font-size:10px;font-weight:700;text-align:center}
.dtbl th.left{text-align:left}
.dtbl td{padding:5px 8px;border-bottom:1px solid var(--g100);text-align:center;color:var(--g900)}
.dtbl td.left{text-align:left;font-weight:600;color:var(--g700);white-space:nowrap}
.dtbl .total-row td{background:var(--g50);font-weight:700;border-top:2px solid var(--g200)}
.upload-progress{height:5px;background:var(--g100);border-radius:20px;overflow:hidden;margin-top:8px;display:none}
.upload-progress-fill{height:100%;background:var(--green);border-radius:20px;transition:width .3s}
.empty{text-align:center;padding:38px 20px;color:var(--g400)}
.empty-ico{font-size:38px;margin-bottom:8px}
.loading{text-align:center;padding:40px 20px;color:var(--g400)}
.spinner{width:18px;height:18px;border:3px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
.spinner-g{width:28px;height:28px;border:3px solid var(--g100);border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
#toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--green);color:#fff;padding:11px 22px;border-radius:30px;font-size:13px;font-weight:600;box-shadow:var(--shl);opacity:0;pointer-events:none;transition:opacity .3s;z-index:999;white-space:nowrap;max-width:90vw}
#toast.show{opacity:1}#toast.error{background:var(--red)}
@keyframes spin{to{transform:rotate(360deg)}}
@media(max-width:480px){.row2{grid-template-columns:1fr}.kpi-val{font-size:20px}}
</style>
</head>
<body>
<header>
  <div class="hdr">
    <div class="logo-box"><img src="data:image/jpeg;base64," alt="ISM"></div>
    <div class="hdr-brand">
      <h1>Recorrido 5S - Guatemala</h1>
      <span>Industrias San Miguel</span>
    </div>
    <button class="hdr-sync" onclick="cargarTodo()">&#8635; Sync</button>
  </div>
</header>
<nav>
  <div class="tab active" onclick="showTab('nuevo')">+ Nueva</div>
  <div class="tab" onclick="showTab('lista')">Observaciones</div>
  <div class="tab" onclick="showTab('dashboard')">Dashboard</div>
</nav>
<main>

<!-- TAB NUEVO -->
<div id="tab-nuevo" class="section active">
  <div class="card">
    <div class="card-title">&#128203; Nueva observacion</div>
    <div class="fg">
      <label>Semana</label>
      <input type="text" id="f-sem" readonly style="background:var(--g50);font-weight:700;color:var(--green)">
    </div>
    <div class="fg"><label>Responsable de Registro <span class="req">*</span></label><input type="text" id="f-auditor" placeholder="Tu nombre completo" oninput="this.style.borderColor=this.value?'var(--green)':''"></div>
    <div class="fg">
      <label>Area <span class="req">*</span></label>
      <select id="f-area" onchange="updateMaquinas()"><option value="">- Selecciona area -</option></select>
    </div>
    <div class="row2">
      <div class="fg">
        <label>Sector</label>
        <input type="text" id="f-sector" readonly style="background:var(--g50);color:var(--g700)">
      </div>
      <div class="fg" id="fg-maquina">
        <label>Maquina / Equipo</label>
        <select id="f-maquina" disabled><option value="">- Elige area primero -</option></select>
      </div>
    </div>
    <div class="fg">
      <label>Tipo de observacion <span class="req">*</span></label>
      <select id="f-tipo" onchange="autoS()"><option value="">- Selecciona tipo -</option></select>
    </div>
    <div class="fg">
      <label>"S" observada</label>
      <div class="s-sel">
        <button class="s-btn" type="button">1S<span>Clasificar</span></button>
        <button class="s-btn" type="button">2S<span>Ordenar</span></button>
        <button class="s-btn" type="button">3S<span>Limpiar</span></button>
        <button class="s-btn" type="button">4S<span>Estandarizar</span></button>
        <button class="s-btn" type="button">5S<span>Disciplina</span></button>
        <button class="s-btn" type="button">EPP<span>Seguridad</span></button>
      </div>
    </div>
    <div class="fg"><label>Descripcion <span class="req">*</span></label><textarea id="f-obs" placeholder="Describe la situacion encontrada..." oninput="this.style.borderColor=this.value?'var(--green)':''" style="min-height:90px"></textarea></div>
    <div class="fg">
      <label>Responsable del area</label>
      <input type="text" id="f-responsable" readonly style="background:var(--g50);color:var(--g700)" placeholder="Se asigna automaticamente">
    </div>
    <div class="fg">
      <label>Foto de evidencia (antes) <span class="req">*</span></label>
      <div class="photo-drop" id="drop-nuevo" style="border-color:var(--red)">
        <input type="file" accept="image/*" capture="environment" multiple onchange="handlePhotos(this)">
        <div style="font-size:28px;margin-bottom:5px">&#128247;</div>
        <p style="font-size:13px;color:var(--g400)">Toca para tomar foto o seleccionar</p>
        <p style="font-size:11px;color:var(--red);font-weight:600;margin-top:4px">Obligatoria</p>
      </div>
      <div class="upload-progress" id="prog-nuevo"><div class="upload-progress-fill" id="prog-nuevo-fill"></div></div>
      <div class="photo-prev" id="prev-nuevo"></div>
    </div>
    <button class="btn-primary" id="btn-guardar" onclick="guardarObservacion()">Guardar observacion</button>
  </div>
</div>

<!-- TAB LISTA -->
<div id="tab-lista" class="section">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
    <select id="fil-area" class="filter-small" onchange="filtrar()"><option value="">Todas las areas</option></select>
    <select id="fil-status" class="filter-small" onchange="filtrar()">
      <option value="">Todos los estados</option>
      <option value="CORREGIDO">Corregido</option>
      <option value="NO CORREGIDO">No corregido</option>
    </select>
    <select id="fil-sector" class="filter-small" onchange="filtrar()"><option value="">Todos los sectores</option></select>
    <select id="fil-sem" class="filter-small" onchange="filtrar()"><option value="">Todas las semanas</option></select>
    <select id="fil-orden" class="filter-small" onchange="filtrar()">
      <option value="reciente">Mas reciente primero</option>
      <option value="antiguo">Mas antiguo primero</option>
      <option value="status">Por estado</option>
      <option value="area">Por area</option>
    </select>
  </div>
  <div id="obs-list"><div class="loading"><div class="spinner-g"></div><p style="margin-top:12px;font-size:13px">Cargando...</p></div></div>
</div>

<!-- TAB DASHBOARD -->
<div id="tab-dashboard" class="section">
  <div style="display:flex;gap:8px;margin-bottom:12px;align-items:center">
    <select id="d-fil-sector" onchange="renderDashboard()" class="filter-small"><option value="">Todos los sectores</option></select>
    <select id="d-fil-area" onchange="renderDashboard()" class="filter-small"><option value="">Todas las areas</option></select>
    <button onclick="exportarPDF()" style="flex-shrink:0;background:var(--red);color:#fff;border:none;border-radius:8px;padding:8px 12px;font-family:Barlow,sans-serif;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap">&#128196; PDF</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:8px">
    <div class="kpi-box"><div class="kpi-val" id="d-total">0</div><div class="kpi-lbl">Total obs.</div></div>
    <div class="kpi-box green"><div class="kpi-val" id="d-corregidas">0</div><div class="kpi-lbl">Corregidas</div></div>
    <div class="kpi-box red"><div class="kpi-val" id="d-no-corr">0</div><div class="kpi-lbl">No Corregidas</div></div>
  </div>
  <div style="margin-bottom:12px">
    <div class="kpi-box amber" style="padding:10px 16px;display:flex;align-items:center;justify-content:space-between">
      <div class="kpi-lbl" style="margin-top:0">% Obs. Corregidas del Total</div>
      <div class="kpi-val" id="d-pct" style="font-size:28px">0%</div>
    </div>
  </div>
  <!-- Mejor/Peor + Comparativo -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
    <div class="dash-card" style="margin-bottom:0">
      <div class="dash-card-title">&#127942; Mejor / Peor area</div>
      <div style="font-size:10px;color:var(--g400);margin:-4px 0 8px;font-style:italic">Semana actual</div>
      <div id="d-top-areas"></div>
    </div>
    <div class="dash-card" style="margin-bottom:0">
      <div class="dash-card-title">&#128200; vs Semana anterior</div>
      <div id="d-comparativo"></div>
    </div>
  </div>
  <!-- Donuts -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
    <div class="dash-card" style="margin-bottom:0">
      <div class="dash-card-title">Estado obs.</div>
      <div style="position:relative;width:100px;height:100px;margin:0 auto">
        <canvas id="chart-donut-status"></canvas>
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:var(--green)" id="d-pct2">0%</div>
          <div style="font-size:8px;color:var(--g400);font-weight:600;text-transform:uppercase">Cumpl.</div>
        </div>
      </div>
      <div id="legend-status" style="margin-top:8px"></div>
    </div>
    <div class="dash-card" style="margin-bottom:0">
      <div class="dash-card-title">Obs. por "S"</div>
      <div style="position:relative;width:100px;height:100px;margin:0 auto">
        <canvas id="chart-donut-s"></canvas>
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:var(--red)" id="d-top-s">-</div>
          <div style="font-size:8px;color:var(--g400);font-weight:600;text-transform:uppercase">Top</div>
        </div>
      </div>
      <div id="legend-s" style="margin-top:8px"></div>
    </div>
  </div>
  <!-- Evolucion -->
  <div class="dash-card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div class="dash-card-title" style="margin-bottom:0">&#128200; Evolucion de observaciones</div>
      <div class="period-sel" style="width:130px">
        <button class="period-btn active" id="btn-sem" onclick="setPeriod('sem')">Semanal</button>
        <button class="period-btn" id="btn-mes" onclick="setPeriod('mes')">Mensual</button>
      </div>
    </div>
    <div style="overflow-x:auto"><canvas id="chart-evolucion" style="min-width:280px"></canvas></div>
  </div>
  <!-- Evolucion por area -->
  <div class="dash-card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div class="dash-card-title" style="margin-bottom:0">&#128202; Evolucion por area</div>
      <div class="period-sel" style="width:130px">
        <button class="period-btn active" id="btn-area-sem" onclick="setPeriodArea('sem')">Semanal</button>
        <button class="period-btn" id="btn-area-mes" onclick="setPeriodArea('mes')">Mensual</button>
      </div>
    </div>
    <div style="overflow-x:auto"><canvas id="chart-area-evol" style="min-width:280px"></canvas></div>
  </div>
  <!-- Sectores -->
  <div class="dash-card">
    <div class="dash-card-title">&#127981; Cumplimiento por sector</div>
    <div style="font-size:10px;color:var(--g400);margin:-4px 0 8px;font-style:italic">Obs. corregidas / total obs. del sector</div>
    <div id="d-sectores"></div>
  </div>
  <!-- Responsables -->
  <div class="dash-card">
    <div class="dash-card-title">&#128100; Cumplimiento por responsable</div>
    <div style="font-size:10px;color:var(--g400);margin:-4px 0 8px;font-style:italic">Obs. corregidas / total obs. asignadas</div>
    <div id="d-responsables"></div>
  </div>
  <!-- Tabla pivot -->
  <div class="dash-card">
    <div class="dash-card-title">&#128203; Resumen por sector y estado</div>
    <div style="overflow-x:auto"><table id="tabla-pivot" class="dtbl"></table></div>
  </div>
  <!-- Tabla cumplimiento area -->
  <div class="dash-card">
    <div class="dash-card-title">% Cumplimiento por area</div>
    <div style="font-size:10px;color:var(--g400);margin:-4px 0 8px;font-style:italic">Mayor % indica mejor desempeno</div>
