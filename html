function getWeek(d){const jan=new Date(d.getFullYear(),0,1);return Math.ceil((((d-jan)/86400000)+jan.getDay()+1)/7);}
function getMes(f){if(!f)return "-";const m=["Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"];const d=new Date(f);return m[d.getMonth()]+" "+d.getFullYear();}
