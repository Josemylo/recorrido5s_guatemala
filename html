function filtrar(){
  const area=document.getElementById("fil-area").value;
  const status=document.getElementById("fil-status").value;
  const sector=document.getElementById("fil-sector").value;
  const orden=document.getElementById("fil-orden").value;
  const semEl=document.getElementById("fil-sem");
  const semCur=semEl.value;
  const sems=[...new Set(observations.map(o=>String(o.sem)).filter(Boolean))].sort((a,b)=>Number(b)-Number(a));
