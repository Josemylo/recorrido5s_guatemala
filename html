  const diff=pctAct-pctAnt;const diffColor=diff>0?G:diff<0?R:A;
  const diffIco=diff>0?"&#9650;":diff<0?"&#9660;":"&#8594;";
  compEl.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px"><div style="text-align:center;flex:1"><div style="font-size:9px;color:var(--g400);font-weight:600;text-transform:uppercase;margin-bottom:2px">Sem. ${semAnt}</div><div style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:var(--g700)">${pctAnt}%</div><div style="font-size:9px;color:var(--g400)">${obsAnt.length} obs.</div></div><div style="text-align:center;padding:0 6px"><div style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:${diffColor}">${diffIco}</div><div style="font-size:10px;color:${diffColor};font-weight:700">${Math.abs(diff)}%</div></div><div style="text-align:center;flex:1"><div style="font-size:9px;color:var(--g400);font-weight:600;text-transform:uppercase;margin-bottom:2px">Sem. ${semActual}</div><div style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:${diffColor}">${pctAct}%</div><div style="font-size:9px;color:var(--g400)">${obsAct.length} obs.</div></div></div><div style="background:${diffColor}18;border-radius:6px;padding:5px 8px;text-align:center"><span style="font-size:10px;font-weight:700;color:${diffColor}">${diff>0?"Mejora":diff<0?"Retroceso":"Sin cambio"}: ${diff>0?"+":""}${diff}% vs sem. anterior</span></div>`;
}
function renderMaquinasRanking(){
  const obsF=getObsFiltradas();
  const G="#00693E",R="#E63329",A="#D97706";
  const today=new Date();today.setHours(0,0,0,0);
  const byMaq={};
  obsF.forEach(o=>{
    if(o.status==="CORREGIDO")return;
    const zona=o.maquina&&o.maquina.trim()?o.maquina:("("+o.area+")");
    const key=o.area+"|||"+zona;
    if(!byMaq[key])byMaq[key]={area:o.area,zona,count:0,diasMax:0,responsable:o.responsable||"-",fallos:{}};
    byMaq[key].count++;
    if(o.fecha){const fObs=new Date(o.fecha+"T00:00:00");const dias=Math.floor((today-fObs)/(1000*60*60*24));if(dias>byMaq[key].diasMax)byMaq[key].diasMax=dias;}
    const s=o.s||"-";byMaq[key].fallos[s]=(byMaq[key].fallos[s]||0)+1;
  });
  const el=document.getElementById("d-maquinas-ranking");if(!el)return;
  const sorted=Object.entries(byMaq).sort((a,b)=>b[1].count-a[1].count).slice(0,10);
  if(!sorted.length){el.innerHTML='<div style="text-align:center;padding:20px;color:var(--green);font-size:13px;font-weight:600">Sin observaciones no corregidas</div>';return;}
  const maxCount=sorted[0][1].count;
  const sCols={"1S":"#E65100","2S":"#1B5E20","3S":"#0D47A1","4S":"#4A148C","5S":"#880E4F","EPP":"#C2410C","-":"#888"};
  el.innerHTML=sorted.map(([key,v],i)=>{
    const pct=Math.round(v.count/maxCount*100);
    const rankColor=i===0?R:i<=2?A:"#555";
    const topFalla=Object.entries(v.fallos).sort((a,b)=>b[1]-a[1])[0];
    const topS=topFalla?topFalla[0]:"-";
    const sCol=sCols[topS]||"#888";
    const diasCol=v.diasMax>14?R:v.diasMax>7?A:G;
    const nombre=v.responsable.length>28?v.responsable.substring(0,26)+"...":v.responsable;
    return `<div style="margin-bottom:10px;padding:10px 12px;background:var(--g50);border-radius:8px;border-left:3px solid ${rankColor}"><div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:6px"><div style="flex:1;min-width:0"><div style="font-size:12px;font-weight:700;color:var(--g900);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${v.zona}</div><div style="font-size:10px;color:var(--g400);margin-top:1px">${v.area}</div></div><span style="background:${rankColor}22;color:${rankColor};font-size:13px;font-weight:800;padding:2px 10px;border-radius:12px;flex-shrink:0">${v.count} obs.</span></div><div style="height:4px;background:var(--g200);border-radius:20px;overflow:hidden;margin-bottom:8px"><div style="height:100%;width:${pct}%;background:${rankColor};border-radius:20px;transition:width .6s"></div></div><div style="display:flex;gap:8px;flex-wrap:wrap;font-size:10px"><span style="background:${diasCol}18;color:${diasCol};padding:2px 7px;border-radius:8px;font-weight:600">&#9201; ${v.diasMax===0?"Hoy":v.diasMax+"d sin corregir"}</span><span style="background:${sCol}18;color:${sCol};padding:2px 7px;border-radius:8px;font-weight:600">${topS}</span><span style="background:var(--g100);color:var(--g700);padding:2px 7px;border-radius:8px">&#128100; ${nombre}</span></div></div>`;
  }).join("");
}
async function exportarPDF(){
  const btn=document.querySelector('[onclick="exportarPDF()"]');
  if(btn){btn.textContent="...";btn.disabled=true;}
  try{
    const {jsPDF}=window.jspdf;
    const doc=new jsPDF({orientation:"portrait",unit:"mm",format:"a4"});
    const PW=210,M=14,CW=182;
    const obsF=getObsFiltradas();
    const total=obsF.length,corr=obsF.filter(o=>o.status==="CORREGIDO").length,noCorr=obsF.filter(o=>o.status==="NO CORREGIDO").length;
    const pct=total?Math.round(corr/total*100):0;
    const fecha=new Date().toLocaleDateString("es-GT",{day:"2-digit",month:"long",year:"numeric"});
    const G=[0,105,62],R=[230,51,41],A=[217,119,6],GD=[0,77,46],W=[255,255,255];
    // Header
    doc.setFillColor(...G);doc.rect(0,0,PW,32,"F");
    doc.setFillColor(...A);doc.rect(0,32,PW,1.5,"F");
    const logoB64GT="data:image/jpeg;base64,";
    doc.addImage(logoB64GT,"JPEG",M,3,24,24);
    doc.setTextColor(...W);doc.setFont("helvetica","bold");doc.setFontSize(20);doc.text("REPORTE 5S",PW/2+10,13,{align:"center"});
    doc.setFontSize(9);doc.setFont("helvetica","normal");doc.text("Industrias San Miguel — Guatemala",PW/2+10,20,{align:"center"});
    doc.setFontSize(7.5);doc.text(fecha,PW/2+10,27,{align:"center"});
    let y=38;
    // KPIs
    const kW=(CW-8)/3;
    [{label:"TOTAL OBS.",val:String(total),col:G},{label:"CORREGIDAS",val:String(corr),col:G},{label:"NO CORREGIDAS",val:String(noCorr),col:R}].forEach((k,i)=>{
      const x=M+i*(kW+4);
      doc.setFillColor(245,248,246);doc.setDrawColor(200,216,204);doc.roundedRect(x,y,kW,18,2,2,"FD");
      doc.setFillColor(...k.col);doc.rect(x,y,kW,1.8,"F");
      doc.setTextColor(...k.col);doc.setFont("helvetica","bold");doc.setFontSize(20);doc.text(k.val,x+kW/2,y+11,{align:"center"});
      doc.setTextColor(100,100,100);doc.setFont("helvetica","normal");doc.setFontSize(7);doc.text(k.label,x+kW/2,y+16,{align:"center"});
    });
    y+=22;
    // Barra cumplimiento
    const pctCol=pct>=80?G:pct>=50?A:R;
    doc.setFillColor(220,240,230);doc.roundedRect(M,y,CW,10,2,2,"F");
    doc.setFillColor(...pctCol);doc.roundedRect(M,y,CW*(pct/100),10,2,2,"F");
    doc.setTextColor(...W);doc.setFont("helvetica","bold");doc.setFontSize(9);
    doc.text(`% CUMPLIMIENTO: ${pct}%  (${corr} corregidas de ${total} observaciones)`,PW/2,y+6.5,{align:"center"});
    y+=15;
    // Analisis
    const byArea={};obsF.forEach(o=>{if(!byArea[o.area])byArea[o.area]={t:0,ok:0,no:0};byArea[o.area].t++;if(o.status==="CORREGIDO")byArea[o.area].ok++;else byArea[o.area].no++;});
    const topArea=Object.entries(byArea).sort((a,b)=>b[1].t-a[1].t)[0];
    const mejorArea=Object.entries(byArea).filter(([,v])=>v.t>=2).sort((a,b)=>(b[1].ok/b[1].t)-(a[1].ok/a[1].t))[0];
    const peorArea=Object.entries(byArea).filter(([,v])=>v.t>=2).sort((a,b)=>(a[1].ok/a[1].t)-(b[1].ok/b[1].t))[0];
    const byS={};obsF.forEach(o=>{const k=o.s||"-";byS[k]=(byS[k]||0)+1;});
    const topS=Object.entries(byS).sort((a,b)=>b[1]-a[1])[0];
    const sems=[...new Set(obsF.map(o=>String(o.sem)).filter(Boolean))].sort((a,b)=>Number(b)-Number(a));
    let tendTxt="";
    if(sems.length>=2){
      const ult=obsF.filter(o=>String(o.sem)===sems[0]);const ant=obsF.filter(o=>String(o.sem)===sems[1]);
      const pU=ult.length?Math.round(ult.filter(o=>o.status==="CORREGIDO").length/ult.length*100):0;
      const pA=ant.length?Math.round(ant.filter(o=>o.status==="CORREGIDO").length/ant.length*100):0;
      const diff=pU-pA;
      tendTxt=diff>0?`Tendencia positiva: sem. ${sems[0]} subio ${diff}% vs sem. ${sems[1]}.`:diff<0?`Tendencia negativa: sem. ${sems[0]} bajo ${Math.abs(diff)}% vs sem. ${sems[1]}.`:`Sin variacion entre sem. ${sems[0]} y ${sems[1]}.`;
    }
    const lineas=[
      `Se registraron ${total} observaciones: ${corr} corregidas (${pct}%) y ${noCorr} no corregidas.`,
      topArea?`Area con mas observaciones: ${topArea[0]} (${topArea[1].t} casos).`:"",
      mejorArea?`Mejor cumplimiento: ${mejorArea[0]} con ${Math.round(mejorArea[1].ok/mejorArea[1].t*100)}% corregido.`:"",
      peorArea&&peorArea[0]!==mejorArea?.[0]?`Area critica: ${peorArea[0]} con ${Math.round(peorArea[1].ok/peorArea[1].t*100)}% corregido.`:"",
      topS?`Falla mas frecuente: ${topS[0]} con ${topS[1]} observaciones.`:"",
      tendTxt
    ].filter(Boolean);
    const rH=lineas.length*6+10;
    doc.setFillColor(240,250,245);doc.setDrawColor(...G);doc.setLineWidth(0.5);doc.roundedRect(M,y,CW,rH,2,2,"FD");
    doc.setFillColor(...G);doc.rect(M,y,3,rH,"F");
    doc.setTextColor(...GD);doc.setFont("helvetica","bold");doc.setFontSize(8);doc.text("ANALISIS EJECUTIVO",M+6,y+5);
    doc.setFont("helvetica","normal");doc.setTextColor(30,60,40);doc.setFontSize(7.5);
    lineas.forEach((l,i)=>{const lines=doc.splitTextToSize("* "+l,CW-10);doc.text(lines,M+6,y+10+i*6);});
    y+=rH+6;
    // Tabla sectores
    const sects={};obsF.forEach(o=>{const s=o.sector||"-";if(!sects[s])sects[s]={corr:0,no:0,total:0};sects[s].total++;if(o.status==="CORREGIDO")sects[s].corr++;else sects[s].no++;});
    const totR={corr:0,no:0,total:0};Object.values(sects).forEach(v=>{totR.corr+=v.corr;totR.no+=v.no;totR.total+=v.total;});
    const pivotBody=Object.entries(sects).sort().map(([k,v])=>[k,v.corr,v.no,v.total,(v.total?Math.round(v.corr/v.total*100):0)+"%"]);
    pivotBody.push(["TOTAL GENERAL",totR.corr,totR.no,totR.total,(totR.total?Math.round(totR.corr/totR.total*100):0)+"%"]);
    doc.setFont("helvetica","bold");doc.setFontSize(8);doc.setTextColor(...G);doc.text("RESUMEN POR SECTOR",M,y);y+=3;
    doc.autoTable({startY:y,head:[["Sector","Corregidas","No Corregidas","Total","% Cumpl."]],body:pivotBody,theme:"grid",headStyles:{fillColor:G,textColor:W,fontSize:7.5,fontStyle:"bold",halign:"center",cellPadding:2},bodyStyles:{fontSize:7.5,halign:"center",cellPadding:2},columnStyles:{0:{halign:"left",fontStyle:"bold",cellWidth:40}},didDrawCell:(d)=>{if(d.section==="body"){if(d.column.index===4){const v=parseInt(d.cell.text[0]);if(!isNaN(v))d.cell.styles.textColor=v>=80?G:v>=50?A:R;d.cell.styles.fontStyle="bold";}if(d.row.index===pivotBody.length-1){d.cell.styles.fillColor=[220,240,230];d.cell.styles.fontStyle="bold";}}},margin:{left:M,right:M}});
    y=doc.lastAutoTable.finalY+6;
    // Tabla areas
    const areaBody=Object.entries(byArea).sort((a,b)=>b[1].t-a[1].t).map(([area,v])=>[area.length>25?area.substring(0,23)+"...":area,v.ok,v.no,v.t,(v.t?Math.round(v.ok/v.t*100):0)+"%"]);
    doc.setFont("helvetica","bold");doc.setFontSize(8);doc.setTextColor(...G);doc.text("% CUMPLIMIENTO POR AREA",M,y);y+=3;
    doc.autoTable({startY:y,head:[["Area","Corregidas","No Corregidas","Total","% Cumpl."]],body:areaBody,theme:"striped",headStyles:{fillColor:GD,textColor:W,fontSize:7.5,fontStyle:"bold",halign:"center",cellPadding:2},bodyStyles:{fontSize:7,halign:"center",cellPadding:2},alternateRowStyles:{fillColor:[242,250,246]},columnStyles:{0:{halign:"left",cellWidth:52}},didDrawCell:(d)=>{if(d.section==="body"&&d.column.index===4){const v=parseInt(d.cell.text[0]);if(!isNaN(v))d.cell.styles.textColor=v>=80?G:v>=50?A:R;d.cell.styles.fontStyle="bold";}},margin:{left:M,right:M}});
    y=doc.lastAutoTable.finalY+6;
    // Tendencia semanal
    if(sems.length>0&&y<250){
      const semData=sems.slice(0,6).reverse().map(s=>{const obs=obsF.filter(o=>String(o.sem)===s);const c=obs.filter(o=>o.status==="CORREGIDO").length;const n=obs.filter(o=>o.status==="NO CORREGIDO").length;const t=obs.length;return ["Sem. "+s,c,n,t,(t?Math.round(c/t*100):0)+"%"];});
      doc.setFont("helvetica","bold");doc.setFontSize(8);doc.setTextColor(...G);doc.text("TENDENCIA SEMANAL",M,y);y+=3;
      doc.autoTable({startY:y,head:[["Semana","Corregidas","No Corregidas","Total","% Cumpl."]],body:semData,theme:"plain",headStyles:{fillColor:GD,textColor:W,fontSize:7,fontStyle:"bold",halign:"center",cellPadding:2},bodyStyles:{fontSize:7,halign:"center",cellPadding:2},columnStyles:{0:{halign:"left",fontStyle:"bold",cellWidth:25}},didDrawCell:(d)=>{if(d.section==="body"&&d.column.index===4){const v=parseInt(d.cell.text[0]);if(!isNaN(v))d.cell.styles.textColor=v>=80?G:v>=50?A:R;d.cell.styles.fontStyle="bold";}},margin:{left:M,right:M}});
    }
    // Footer
    doc.setFillColor(...G);doc.rect(0,285,PW,12,"F");
    doc.setTextColor(...W);doc.setFont("helvetica","normal");doc.setFontSize(7);
    doc.text("Guatemala — Programa 5S",M,291);doc.text(fecha,PW/2,291,{align:"center"});doc.text("Pagina 1 de 1",PW-M,291,{align:"right"});
    const semLabel=sems[0]?"_Sem"+sems[0]:"";
    doc.save(`Reporte5S_GT${semLabel}_${new Date().toISOString().split("T")[0]}.pdf`);
    showToast("PDF generado");
  }catch(e){console.error(e);showToast("Error PDF: "+e.message,true);}
  if(btn){btn.textContent="PDF";btn.disabled=false;}
}
function showTab(name){
  document.querySelectorAll(".section").forEach(s=>s.classList.remove("active"));
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
  document.getElementById("tab-"+name).classList.add("active");
  ["nuevo","lista","dashboard"].forEach((t,i)=>{if(t===name)document.querySelectorAll(".tab")[i].classList.add("active");});
  if(name==="lista")filtrar();
  if(name==="dashboard")renderDashboard();
}
function openModal(id){document.getElementById(id).classList.add("show");document.body.style.overflow="hidden";}
function closeModal(id){document.getElementById(id).classList.remove("show");document.body.style.overflow="";}
let toastT;
function showToast(msg,isErr){const t=document.getElementById("toast");t.textContent=msg;t.className="show"+(isErr?" error":"");clearTimeout(toastT);toastT=setTimeout(()=>t.className="",3500);}
</script>
